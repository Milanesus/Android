<?xml version="1.0" encoding="utf-8"?>
<!-- Usamos ScrollView para que el contenido se pueda desplazar si la información es muy extensa -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/fondo_interfaz">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Encabezado del reporte del perfil -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_reporte"
            android:textSize="28sp"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/black"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center_horizontal" />

        <!-- Foto de Perfil en el Reporte -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivFotoReporte"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:scaleType="centerCrop"
            android:src="@drawable/foto_perfil"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/white"
            app:strokeWidth="4dp"
            android:padding="2dp"
            android:background="@color/white"
            android:elevation="4dp" />

        <!-- Nombre Completo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reporte_nombre"
            android:textSize="22sp"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/tvNombreValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_regular"
            android:breakStrategy="simple"
            android:layout_marginBottom="12dp" />

        <!-- Fecha de Nacimiento con Icono -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/calendario"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reporte_fecha_nacimiento"
                android:textSize="22sp"
                android:fontFamily="@font/roboto_bold"
                android:textColor="@color/black" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFechaNacimientoValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_regular"
            android:breakStrategy="simple"
            android:layout_marginBottom="12dp" />

        <!-- Selección de Género -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reporte_genero"
            android:textSize="22sp"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/tvGeneroValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_regular"
            android:breakStrategy="simple"
            android:layout_marginBottom="12dp" />

        <!-- Teléfono con Icono -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_call"
                app:tint="@color/black"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reporte_telefono"
                android:textSize="22sp"
                android:fontFamily="@font/roboto_bold"
                android:textColor="@color/black" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTelefonoValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_regular"
            android:breakStrategy="simple"
            android:layout_marginBottom="12dp" />

        <!-- Correo con Icono -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/correo"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reporte_correo"
                android:textSize="22sp"
                android:fontFamily="@font/roboto_bold"
                android:textColor="@color/black" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCorreoValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_regular"
            android:breakStrategy="simple"
            android:layout_marginBottom="12dp" />

        <!-- Sección de Intereses -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reporte_intereses"
            android:textSize="22sp"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/tvInteresesValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_regular"
            android:breakStrategy="simple"
            android:layout_marginBottom="12dp" />

        <!-- Sección de Biografía -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reporte_biografia"
            android:textSize="22sp"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/tvBiografiaValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_regular"
            android:breakStrategy="simple" />

    </LinearLayout>
</ScrollView>